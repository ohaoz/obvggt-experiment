{
  "variant": "obcache_p1_no_recent_ctrl_cuda_rope",
  "description": "Runtime experiment: p1_no_recent_ctrl with StreamVGGT RoPE2D forced to compiled croco cuRoPE2D when eligible.",
  "runnable": true,
  "repo_path": ".",
  "model_family": "OBVGGT",
  "model_name": "StreamVGGT",
  "env_name": "obvggt",
  "adapter": "run_obvggt.py",
  "supported_tasks": [
    "video_depth"
  ],
  "default_args": [
    "--rope2d_backend",
    "cuda"
  ],
  "kv_policy_summary": "Same as p1_no_recent_ctrl; only StreamVGGT RoPE2D backend is forced to cuda.",
  "kv_cache_enable": true,
  "kv_cache_cfg": {
    "enable": true,
    "method": "obcvk",
    "p": 1,
    "use_vnorm": true,
    "num_sink_frames": 1,
    "num_recent_frames": 0,
    "num_heavy_frames": 4,
    "probe_mode": true,
    "num_patch_probes": 8
  },
  "model": "StreamVGGT",
  "checkpoint": "ckpt/checkpoints.pth"
}
