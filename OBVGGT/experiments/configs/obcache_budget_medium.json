{
  "variant": "obcache_budget_medium",
  "description": "Ablation: Medium budget (sink=1, recent=3, heavy=6)",
  "runnable": true,
  "repo_path": ".",
  "model_family": "OBVGGT",
  "model_name": "StreamVGGT",
  "env_name": "obvggt",
  "adapter": "run_obvggt.py",
  "supported_tasks": [
    "monodepth",
    "video_depth",
    "mv_recon",
    "pose_co3d"
