  "kv_policy_summary": "Ablation: Medium token budget (1+3+6 frames).",
  "kv_cache_enable": true,
  "kv_cache_cfg": {
    "enable": true,
    "method": "obcvk",
    "p": 2,
    "use_vnorm": true,
    "num_sink_frames": 1,
    "num_recent_frames": 3,
    "num_heavy_frames": 6,
    "probe_mode": true,
    "num_patch_probes": 8
  },
  "model": "StreamVGGT",
  "checkpoint": "ckpt/checkpoints.pth"
}
