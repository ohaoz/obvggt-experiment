{
  "variant": "obcache_random_s1",
  "description": "Ablation: Random eviction baseline (seed 1, for variance estimation)",
  "runnable": true,
  "repo_path": ".",
  "model_family": "OBVGGT",
  "model_name": "StreamVGGT",
  "env_name": "obvggt",
  "adapter": "run_obvggt.py",
  "supported_tasks": [
    "monodepth",
    "video_depth",
    "mv_recon",
    "pose_co3d"
  ],
  "kv_policy_summary": "Ablation: Random eviction (seed 1, repeat run for variance).",
  "default_args": [
    "--seed",
    "1"
  ],
  "kv_cache_enable": true,
  "kv_cache_cfg": {
    "enable": true,
    "method": "random",
    "num_sink_frames": 1,
    "num_recent_frames": 2,
    "num_heavy_frames": 4,
    "probe_mode": true,
    "num_patch_probes": 8
  },
  "model": "StreamVGGT",
  "checkpoint": "ckpt/checkpoints.pth"
}
