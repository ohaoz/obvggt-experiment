{
  "variant": "obcache_sliding_window",
  "description": "Ablation: Sliding window baseline (no heavy hitter selection)",
  "runnable": true,
  "repo_path": ".",
  "model_family": "OBVGGT",
  "model_name": "StreamVGGT",
  "env_name": "obvggt",
  "adapter": "run_obvggt.py",
  "supported_tasks": [
    "monodepth",
    "video_depth",
    "mv_recon",
    "pose_co3d"
  ],
  "kv_policy_summary": "Ablation: Sliding window, keep only recent frames.",
  "kv_cache_enable": true,
  "kv_cache_cfg": {
    "enable": true,
    "method": "sliding_window",
    "num_sink_frames": 0,
    "num_recent_frames": 7,
    "num_heavy_frames": 0,
    "probe_mode": false
  },
  "model": "StreamVGGT",
  "checkpoint": "ckpt/checkpoints.pth"
}
